# ─────────────────────────────────────────────────────────────────────────────
#  FX Radiant — frontend environment
#
#  Change VITE_API_URL and VITE_WS_URL if your Mac's LAN IP changes.
#  Run `ifconfig | grep "inet "` on the Mac to find it.
#
#  Android emulator special case: use 10.0.2.2 instead of the LAN IP.
# ─────────────────────────────────────────────────────────────────────────────

# Mac LAN IP — all devices on the same Wi-Fi network can reach this
VITE_API_URL=http://192.168.0.157:8000
VITE_WS_URL=ws://192.168.0.157:8000/ws

